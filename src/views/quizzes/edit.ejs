<h2>Edit Quiz</h2>

<form action="/quizzes/edit/<%= quiz._id %>" method="POST">

    <div>
        <label>Title:</label><br>
        <input type="text" name="title" value="<%= quiz.title %>" required style="width:300px;">
    </div>

    <br>

    <div>
        <label>Description:</label><br>
        <textarea name="description" rows="4" cols="50"><%= quiz.description %></textarea>
    </div>

    <br>

    <button type="submit">Update Quiz</button>
    <button>
        <a href="/quizzes">Cancel</a>
    </button>
</form>